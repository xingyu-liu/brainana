@startuml macacaMRIprep_Core_Components

!theme _none_
skinparam componentStyle rectangle
skinparam componentFontSize 12
skinparam packageFontSize 14
skinparam packageFontStyle bold

package "macacaMRIprep Core Architecture" {
    
    component "BIDS Dataset Processor" as BIDS {
        [BIDSDatasetProcessor] as bids_main
        [BaseJob] as base_job
        [AnatomicalJob] as anat_job
        [FunctionalJob] as func_job
        
        note right of bids_main
            Central orchestrator:
            - Discovers BIDS dataset structure
            - Handles cross-session dependencies
            - Creates processing jobs
            - Manages multi-run T1w synthesis
        end note
    }
    
    component "Workflow Processors" as WORKFLOW {
        [BasePreprocessingWorkflow] as base_workflow
        [FunctionalProcessor] as func_processor
        [AnatomicalProcessor] as anat_processor
        
        note right of anat_processor
            Anatomical Processing:
            1. Bias correction
            2. Skullstripping
            3. Registration to template
        end note
        
        note right of func_processor
            Functional Processing:
            1. Slice timing correction
            2. Motion correction
            3. Despiking
            4. Bias correction
            5. Skullstripping
            6. Registration to target
        end note
    }
    
    component "Pipeline Management" as PIPELINE {
        [Pipeline] as pipeline
        [PipelineState] as pipeline_state
        
        note right of pipeline
            Execution engine:
            - Manages processing order
            - Handles error recovery
            - Coordinates operations
            - Maintains state
        end note
    }
    
    component "Processing Operations" as OPERATIONS {
        [preprocessing] as preproc
        [registration] as reg
        [skullstripping] as skull

        note right of preproc
            Preprocessing:
            - Slice timing correction
            - Motion correction
            - Despiking
            - Bias correction
        end note

    }
    
    component "Quality Control" as QC {
        [create_motion_correction_qc] as motion_qc
        [create_skullstripping_qc] as skull_qc
        [create_registration_qc] as reg_qc
        [generate_qc_report] as qc_reports
    }
}

' Core Relationships
BIDS --> WORKFLOW : creates jobs
WORKFLOW --> PIPELINE : uses for execution
PIPELINE --> OPERATIONS : executes operations
OPERATIONS --> QC : generates metrics

' Detailed Relationships
bids_main --> anat_job : creates
bids_main --> func_job : creates
anat_job --> anat_processor : instantiates
func_job --> func_processor : instantiates

anat_processor --> pipeline : uses
func_processor --> pipeline : uses

pipeline --> preproc : calls
pipeline --> reg : calls
pipeline --> skull : calls

preproc --> motion_qc : generates
skull --> skull_qc : generates
reg --> reg_qc : generates

' Data Flow
note top of BIDS : Input: BIDS Dataset
note bottom of QC : Output: Processed Data + QC Reports

@enduml 