@startuml macacaMRIprep_Workflow_Sequence

!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor User
participant "preproc.main" as CLI
participant "BIDSDatasetProcessor" as BIDS
participant "Config" as Config
participant "check_environment" as Env
participant "check_dependencies" as Dep
participant "BasePreprocessingWorkflow" as Base
participant "Pipeline" as Pipeline
participant "AnatomicalProcessor" as Anat
participant "FunctionalProcessor" as Func
participant "preprocessing" as Preproc
participant "skullstripping" as Skull
participant "registration" as Reg
participant "quality_control" as QC

User -> CLI: macacaMRIprep-preproc dataset output --output-space template
activate CLI

CLI -> CLI: parse_args
CLI -> Config: load_and_merge_config
activate Config
Config --> CLI: config_dict
deactivate Config

CLI -> CLI: validate_arguments
CLI -> CLI: print_configuration

CLI -> Dep: check_dependencies
activate Dep
Dep --> CLI: dependencies_ok
deactivate Dep

CLI -> Env: check_environment
activate Env
Env --> CLI: environment_ok
deactivate Env

CLI -> BIDS: __init__
activate BIDS

BIDS -> BIDS: _setup_dataset_logging
BIDS -> BIDS: _setup_bids_derivatives
BIDS -> BIDS: _load_cache

BIDS -> BIDS: discover_processing_jobs
activate BIDS
BIDS -> BIDS: _create_anatomical_jobs
BIDS -> BIDS: _create_functional_jobs
BIDS --> BIDS: jobs_list
deactivate BIDS

BIDS -> BIDS: run_dataset
activate BIDS

note over BIDS: **PHASE 0: Cache and Completion Check**

BIDS -> BIDS: check_job_completion for all jobs
activate BIDS
BIDS --> BIDS: completed_jobs, pending_jobs
deactivate BIDS

note over BIDS: **PHASE 1: ANATOMICAL PROCESSING**\nAll anatomical jobs processed first

loop For each anatomical job
    BIDS -> Anat: _process_anatomical_job
    activate Anat
    
    Anat -> Anat: __init__
    Anat -> Base: __init__
    activate Base
    Base -> Config: validate_config
    Base -> Pipeline: __init__
    activate Pipeline
    Pipeline --> Base: pipeline_instance
    deactivate Pipeline
    Base --> Anat: base_workflow
    deactivate Base
    
    Anat -> Anat: run
    activate Anat
    
    Anat -> Preproc: bias_correction
    activate Preproc
    Preproc --> Anat: bias_corrected_file
    deactivate Preproc
    
    Anat [#0066CC]-> QC: create_bias_correction_qc
    activate QC
    QC -[#0066CC]-> Anat: anat_bias_qc_snapshot
    deactivate QC
    
    Anat -> Skull: skullstripping
    activate Skull
    Skull -> Skull: _load_model
    Skull -> Skull: predict_brain_mask
    Skull --> Anat: brain_mask
    deactivate Skull
    
    Anat [#0066CC]-> QC: create_skullstripping_qc
    activate QC
    QC -[#0066CC]-> Anat: anat_skull_qc_snapshot
    deactivate QC
    
    Anat -> Reg: ants_register
    activate Reg
    Reg --> Anat: registered_file
    deactivate Reg
    
    Anat [#0066CC]-> QC: create_registration_qc
    activate QC
    QC -[#0066CC]-> Anat: anat_reg_qc_snapshot
    deactivate QC
    
    Anat --> BIDS: anat_result
    deactivate Anat
end

BIDS -> BIDS: _save_cache after anatomical processing

note over BIDS: **PHASE 2: FUNCTIONAL PROCESSING**\nAll functional jobs processed after anatomical dependencies complete

loop For each functional job (dependency check passed)
    BIDS -> Func: _process_functional_job
    activate Func
    
    Func -> Func: __init__
    Func -> Base: __init__
    activate Base
    Base --> Func: base_workflow
    deactivate Base
    
    Func -> Func: run
    activate Func
    
    Func -> Preproc: precheck
    activate Preproc
    Preproc --> Func: func_tmean
    deactivate Preproc
    
    Func -> Preproc: slice_timing_correction
    activate Preproc
    Preproc --> Func: slice_timed_file
    deactivate Preproc
    
    Func -> Preproc: motion_correction
    activate Preproc
    Preproc --> Func: motion_corrected_file
    deactivate Preproc
    
    Func [#0066CC]-> QC: create_motion_correction_qc
    activate QC
    QC -[#0066CC]-> Func: motion_qc_snapshot
    deactivate QC
    
    Func -> Preproc: despike
    activate Preproc
    Preproc --> Func: despiked_file
    deactivate Preproc
    
    Func -> Preproc: bias_correction
    activate Preproc
    Preproc --> Func: bias_corrected_file
    deactivate Preproc
    
    Func -> Skull: skullstripping
    activate Skull
    Skull --> Func: func_brain_mask
    deactivate Skull
    
    Func [#0066CC]-> QC: create_skullstripping_qc
    activate QC
    QC -[#0066CC]-> Func: func_skull_qc_snapshot
    deactivate QC
    
    Func -> Reg: ants_register
    activate Reg
    Reg --> Func: registered_file
    deactivate Reg
    
    Func -> Reg: ants_apply_transforms
    activate Reg
    Reg --> Func: final_func_file
    deactivate Reg
    
    Func [#0066CC]-> QC: create_registration_qc
    activate QC
    QC -[#0066CC]-> Func: func_reg_qc_snapshot
    deactivate QC
    
    Func --> BIDS: func_result
    deactivate Func
end

BIDS -> BIDS: _save_cache after functional processing

note over BIDS: **PHASE 3: QC REPORT GENERATION**

BIDS [#0066CC]-> BIDS: _generate_subject_reports
activate BIDS
BIDS [#0066CC]-> QC: generate_qc_report
activate QC
QC -[#0066CC]-> BIDS: qc_report
deactivate QC
deactivate BIDS

BIDS -> BIDS: _save_cache final save
BIDS -> BIDS: clear_cache if successful

BIDS --> CLI: dataset_result
deactivate BIDS

CLI --> User: Processing complete
deactivate CLI

@enduml 