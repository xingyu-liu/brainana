/*
 * Nextflow configuration file for brainana
 */

// Centralized work directory - keeps project directory clean
// Priority: --work_dir parameter > NXF_WORK env var > ~/.nextflow/work
// Log files: Set NXF_LOG environment variable to control log file location
//   Example: export NXF_LOG=$HOME/.nextflow/logs/nextflow.log
workDir = params.work_dir ?: System.getenv('NXF_WORK') ?: "${System.getProperty('user.home')}/.nextflow/work"

// Docker configuration
// Set NXF_NO_DOCKER=1 environment variable to disable Docker for local development
def dockerEnabled = !System.getenv('NXF_NO_DOCKER')

// Detect Python environment (uv, virtualenv, or conda) when running without Docker
// Prioritize VIRTUAL_ENV (uv/virtualenv) over CONDA_PREFIX to prefer user's active environment
def pythonEnv = System.getenv('VIRTUAL_ENV') ?: System.getenv('CONDA_PREFIX')
def pythonEnvBinPath = pythonEnv ? "${pythonEnv}/bin" : null
def pythonExe = pythonEnv ? "${pythonEnv}/bin/python3" : "python3"

// Make pythonExe available globally for use in process scripts
params.python_exe = pythonExe

// GPU auto-detection: count available GPUs at config parse time
// Returns 0 if nvidia-smi is not available (no NVIDIA GPU)
def gpuCount = 0
try {
    def proc = "nvidia-smi --list-gpus".execute()
    proc.waitFor()
    if (proc.exitValue() == 0) {
        gpuCount = proc.text.trim().split('\n').findAll { it.trim() }.size()
    }
} catch (Exception e) {
    // nvidia-smi not available, keep gpuCount = 0
}
// Estimate max concurrent jobs per GPU based on free VRAM
// Assumes ~4 GiB per job. Uses minimum free VRAM across GPUs.
def maxJobsPerGpu = 1
def perJobVramMiB = 4096
try {
    def proc = "nvidia-smi --query-gpu=memory.free --format=csv,noheader,nounits".execute()
    proc.waitFor()
    if (proc.exitValue() == 0) {
        def freeValues = proc.text
            .trim()
            .split('\n')
            .collect { it.trim() }
            .findAll { it }
            .collect { it as Integer }
        if (freeValues && freeValues.size() > 0) {
            def minFreeMiB = freeValues.min()
            def computed = (int) Math.floor(minFreeMiB / perJobVramMiB)
            def bounded = Math.min(Math.max(computed, 1), 4)
            maxJobsPerGpu = bounded
        }
    }
} catch (Exception e) {
    // nvidia-smi not available, keep default maxJobsPerGpu = 1
}

// Containers run as root (no --user) so GPU access works on any host. Output files may be root-owned; chown after the run if needed.
// When GPUs are detected, pass them into containers so GPU processes (e.g. skullstripping) can use them.
def dockerRunOpts = (dockerEnabled && gpuCount > 0) ? '--gpus all' : ''
docker {
    enabled = dockerEnabled
    runOptions = dockerRunOpts
}

// Pre-build Python environment activation script at config parse time
// This is used in beforeScript closure along with runtime task.cpus
def pythonActivationScript = pythonEnv && !dockerEnabled ? """
# Activate Python environment (supports uv, virtualenv, and conda)
if [ -f "${pythonEnv}/etc/profile.d/conda.sh" ]; then
    # Conda environment
    source "${pythonEnv}/etc/profile.d/conda.sh"
    conda activate "${pythonEnv}"
elif [ -f "${pythonEnv}/bin/activate" ]; then
    # UV or virtualenv environment
    source "${pythonEnv}/bin/activate"
fi
# Ensure python3 points to the environment's Python
export PATH="${pythonEnvBinPath}:\$PATH"
# Set PYTHON to the environment's Python (override any previous setting)
export PYTHON="${pythonExe}"
# Ensure PYTHONPATH includes src/ for module imports
export PYTHONPATH="${projectDir}/src:\${PYTHONPATH:-}"
""" : ""

// Default process configuration
process {
    // Only use container if Docker is enabled
    container = dockerEnabled ? 'brainana:latest' : null
    
    // Default resource allocation (light processes)
    // Heavy/medium processes override these in their definitions
    cpus = 1
    memory = '2 GB'
    
    // Thread management: Set thread environment variables based on task.cpus
    // Thread count automatically matches CPU allocation (task.cpus)
    // This ensures numerical libraries (OpenMP, MKL, ITK, etc.) use the allocated CPUs
    // Python code reads OMP_NUM_THREADS from environment (set here)
    env {
        // Add src/ to Python path for module imports
        PYTHONPATH = "${projectDir}/src:\$PYTHONPATH"
        // Add Python environment bin to PATH when available and Docker is disabled
        PATH = pythonEnvBinPath && !dockerEnabled ? "${pythonEnvBinPath}:\$PATH" : "\$PATH"
        // Set Python executable to use environment Python when available and Docker is disabled
        // Always set PYTHON to ensure it's available in scripts (defaults to python3)
        // Note: This is evaluated at config load time, so beforeScript will override if needed
        PYTHON = pythonEnv && !dockerEnabled ? pythonExe : "python3"
    }
    
    // Activate Python environment and set thread variables before script execution
    // Thread count is set dynamically based on task.cpus - must use closure for runtime access
    beforeScript = {
        """
        # Set thread environment variables based on CPU allocation
        export OMP_NUM_THREADS=${task.cpus}
        export MKL_NUM_THREADS=${task.cpus}
        export NUMEXPR_NUM_THREADS=${task.cpus}
        export OPENBLAS_NUM_THREADS=${task.cpus}
        export ITK_GLOBAL_DEFAULT_NUMBER_OF_THREADS=${task.cpus}
        
        ${pythonActivationScript}
        """
    }
    
    // Default error strategy
    // General retry: all processes get 1 retry attempt by default
    // Processes with explicit retry configs (e.g., maxRetries = 3) override this
    errorStrategy = 'retry'
    maxRetries = 1
    
    // Publish directory settings
    publishDir = [
        mode: 'copy',
        overwrite: false
    ]
    
    // ============================================
    // RESOURCE ALLOCATION BY PROCESS
    // Calibrated from five datasets (D1–D5); max peak_rss across all used for config.
    // See docs_temp/RESOURCE_CALIBRATION.md and docs/RESOURCE_USAGE_SUMMARY.md
    // ============================================
    
    // GPU process configuration
    // Limit parallel GPU jobs: gpu_count * max_jobs_per_gpu
    // Each job is assigned a GPU via CUDA_VISIBLE_DEVICES using round-robin (task.index % gpu_count)
    withLabel: 'gpu' {
        maxForks = gpuCount > 0 ? gpuCount * maxJobsPerGpu : 1
    }
    
    // --------------------------------------------
    // HEAVY PROCESSES - Strict parallelism limits
    // These processes have high memory usage and/or long duration
    // --------------------------------------------
    
    // ANAT_SURFACE_RECONSTRUCTION: 2.1-10 GB RAM, 14-26% CPU, 1h33m-3h52m typical
    // mris_fix_topology (s12) can run many hours on difficult surfaces; cap whole job duration
    withName: 'ANAT_SURFACE_RECONSTRUCTION' {
        cpus = 1
        memory = { 8.GB * (task.attempt ** 1.5) }
        time = '8h'
        errorStrategy = { task.exitStatus in 137..140 && task.attempt <= 3 ? 'retry' : 'ignore' }
        maxRetries = 3
        maxForks = 1
    }
    
    // FUNC_APPLY_TRANSFORMS: max 14.6 GB peak_rss (D3 across D1–D5); config 16 GB
    withName: 'FUNC_APPLY_TRANSFORMS' {
        cpus = 2
        memory = { 16.GB * (task.attempt ** 1.5) }
        errorStrategy = { task.exitStatus in 137..140 ? 'retry' : 'terminate' }
        maxRetries = 3
        maxForks = 1
    }
    
    // ANAT_SKULLSTRIPPING: 2-6.1 GB RAM, 121-250% CPU, 15m-1h33m
    withName: 'ANAT_SKULLSTRIPPING' {
        cpus = 2
        memory = { 6.GB * (task.attempt ** 1.5) }
        errorStrategy = { task.exitStatus in 137..140 ? 'retry' : 'terminate' }
        maxRetries = 3
        maxForks = 2
    }
    
    // ANAT_REGISTRATION: 2.6-4.6 GB RAM, 101-110% CPU, 1h44m-2h17m
    withName: 'ANAT_REGISTRATION' {
        cpus = 2
        memory = { 5.GB * (task.attempt ** 1.5) }
        errorStrategy = { task.exitStatus in 137..140 ? 'retry' : 'terminate' }
        maxRetries = 3
        maxForks = 2
    }
    
    // FUNC_COMPUTE_REGISTRATION: 1-9.6 GB RAM, 61-300% CPU, 4m-3h53m
    withName: 'FUNC_COMPUTE_REGISTRATION' {
        cpus = 3
        memory = { 8.GB * (task.attempt ** 1.5) }
        errorStrategy = { task.exitStatus in 137..140 ? 'retry' : 'terminate' }
        maxRetries = 3
        maxForks = 2
    }
    
    // FUNC_WITHIN_SES_COREG: ANTs/FLIRT rigid registration + apply to 4D BOLD; similar to FUNC_COMPUTE_REGISTRATION + FUNC_APPLY_TRANSFORMS
    withName: 'FUNC_WITHIN_SES_COREG' {
        cpus = 3
        memory = { 16.GB * (task.attempt ** 1.5) }
        errorStrategy = { task.exitStatus in 137..140 ? 'retry' : 'terminate' }
        maxRetries = 3
        maxForks = 1
    }
    
    // --------------------------------------------
    // MEDIUM PROCESSES - Moderate parallelism
    // --------------------------------------------
    
    // ANAT_T2W_TO_T1W_REGISTRATION: T2w to T1w coregistration using ANTs
    withName: 'ANAT_T2W_TO_T1W_REGISTRATION' {
        cpus = 1
        memory = '6 GB'
    }
    
    // ANAT_CONFORM: 2.1-6.7 GB peak_rss (ElectrodeLocalization), high vmem (FLIRT)
    withName: 'ANAT_CONFORM' {
        cpus = 1
        memory = '8 GB'
    }
    
    // ANAT_BIAS_CORRECTION: 1.8-7.3 GB RAM, 83-110% CPU, 1m-13m
    withName: 'ANAT_BIAS_CORRECTION' {
        cpus = 1
        memory = '8 GB'
    }
    
    // ANAT_SYNTHESIS: 1.7-5.2 GB RAM, 91-158% CPU (GPU process)
    withName: 'ANAT_SYNTHESIS' {
        cpus = 1
        memory = '6 GB'
    }
    
    // FUNC_COMPUTE_CONFORM: max 2 GB peak_rss (D3–D5); peak_vmem 16.7 GB (FLIRT)
    withName: 'FUNC_COMPUTE_CONFORM' {
        cpus = 1
        memory = '6 GB'
    }
    
    // FUNC_APPLY_CONFORM: 1-7.1 GB RAM, 12-16% CPU
    withName: 'FUNC_APPLY_CONFORM' {
        cpus = 1
        memory = '8 GB'
    }
    
    // FUNC_COMPUTE_BRAIN_MASK: 1.8-3.4 GB RAM, 13-23% CPU (GPU process)
    withName: 'FUNC_COMPUTE_BRAIN_MASK' {
        cpus = 1
        memory = '4 GB'
    }
    
    // FUNC_BIAS_CORRECTION: 0.9-1.1 GB RAM, 23-80% CPU
    withName: 'FUNC_BIAS_CORRECTION' {
        cpus = 1
        memory = '2 GB'
    }
    
    // FUNC_MOTION_CORRECTION: observed ~3.1 GB peak_rss (nextflow_report*.html); mcflirt on 4D BOLD
    withName: 'FUNC_MOTION_CORRECTION' {
        cpus = 1
        memory = '6 GB'
    }
    
    // QC processes using Connectome Workbench (wb_command) - high vmem, 2-4 GB peak_rss
    withName: 'QC_SURF_RECON_TISSUE_SEG' {
        cpus = 1
        memory = '4 GB'
    }
    withName: 'QC_CORTICAL_SURF_AND_MEASURES' {
        cpus = 1
        memory = '4 GB'
    }
    
    // --------------------------------------------
    // LIGHT PROCESSES - Default resources (1 CPU, 2 GB)
    // No explicit config needed - uses process defaults
    // Includes: ANAT_REORIENT, ANAT_APPLY_*, ANAT_PUBLISH_*,
    //           FUNC_REORIENT, FUNC_SLICE_TIMING, FUNC_AVERAGE_TMEAN,
    //           FUNC_APPLY_TRANSFORMS_MASK,
    //           Other QC_* processes
    // --------------------------------------------
}

// Default executor configuration
// Global resource cap: Nextflow schedules tasks based on declared cpus/memory
// and only starts new tasks when there's room within these limits.
// Override via NXF_MAX_CPUS and NXF_MAX_MEMORY env vars (e.g. Docker: -e NXF_MAX_MEMORY=20g)
// See docs/RESOURCE_CALIBRATION.md for calibration details.
def executorCpus = System.getenv('NXF_MAX_CPUS') ? System.getenv('NXF_MAX_CPUS').toInteger() : 8
def executorMemory = System.getenv('NXF_MAX_MEMORY') ?: '20 GB'

executor {
    name = 'local'
    cpus = executorCpus
    memory = executorMemory
}

// Executor profiles (for HPC/cloud environments)
// Usage: nextflow run main.nf -profile minimal ...
profiles {
    // Minimal: anat-only, 1-2 subjects (aligns with DeepPrep 12 GB, fMRIPrep 16 GB)
    minimal {
        executor.cpus = 4
        executor.memory = '16 GB'
    }

    // Default: typical local/Docker runs (8 cpus, 20 GB)
    local {
        process.executor = 'local'
    }

    // Recommended: full pipeline, multiple subjects
    recommended {
        executor.cpus = 8
        executor.memory = '32 GB'
    }

    // SLURM HPC
    // SGE HPC
    // AWS Batch
    // Google Cloud Life Sciences
}

// Workflow parameters
// ============================================
// PARAMETER PRIORITY SYSTEM
// ============================================
// Parameters are resolved with the following priority (highest to lowest):
// 1. Command-line arguments (--param value) - highest priority
// 2. YAML config file (template.output_space, general.anat_only, etc.) - medium priority
// 3. defaults.yaml (nhp_mri_prep/config/defaults.yaml) - lowest priority
//
// Parameter resolution is handled centrally by workflows/param_resolver.groovy
// 
// CLI Parameters (can be set via --param):
//   - output_space → maps to template.output_space in YAML
//   - anat_only → maps to general.anat_only in YAML
//   - subjects → maps to bids_filtering.subjects in YAML
//   - sessions → maps to bids_filtering.sessions in YAML
//   - tasks → maps to bids_filtering.tasks in YAML
//   - runs → maps to bids_filtering.runs in YAML
//
// YAML-only Parameters (read from config file only):
//   - All other parameters in defaults.yaml (e.g., func.reorient.enabled,
//     anat.conform.enabled, registration.enabled, etc.)
//
// Workflow-specific Parameters (not in YAML):
//   - bids_dir, output_dir, config_file, work_dir
//   - skip_bids_validation, max_cpus, max_memory, default_threads
//   - gpu_enabled, gpu_queue
// ============================================

params {
    // Input/output (workflow-specific, not in YAML)
    bids_dir = null
    output_dir = null
    config_file = null
    work_dir = null
    
    // Template (CLI parameter, maps to template.output_space in YAML)
    // Default removed - use defaults.yaml instead
    output_space = null
    
    // BIDS filtering (CLI parameters, map to bids_filtering.* in YAML)
    // Defaults removed - use defaults.yaml instead
    subjects = null
    sessions = null
    tasks = null
    runs = null
    
    // Processing options (CLI parameter anat_only maps to general.anat_only in YAML)
    anat_only = null
    skip_bids_validation = false  // Workflow-specific, not in YAML
    
    // GPU settings (workflow-specific, not in YAML)
    gpu_enabled = false
    gpu_queue = 'gpu'
    
    // GPU auto-detection and assignment (values from top-level variables)
    gpu_count = gpuCount
    max_jobs_per_gpu = maxJobsPerGpu
}

// Workflow configuration
workflow {
    // Enable DSL2
    language = 'nextflow'
}

// Report and timeline
// Only generate reports when output_dir is set (i.e., during actual runs, not --help)
// Timestamp in filenames prevents overwriting original run reports when resuming (-resume).
report {
    enabled = params.output_dir != null
    file = params.output_dir ? "${params.output_dir}/nextflow_reports/nextflow_report_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.html" : null
    overwrite = true
}

timeline {
    enabled = params.output_dir != null
    file = params.output_dir ? "${params.output_dir}/nextflow_reports/nextflow_timeline_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.html" : null
    overwrite = true
}

trace {
    enabled = params.output_dir != null
    file = params.output_dir ? "${params.output_dir}/nextflow_reports/nextflow_trace.txt" : null
    overwrite = true
}

dag {
    enabled = params.output_dir != null
    file = params.output_dir ? "${params.output_dir}/nextflow_reports/nextflow_dag.svg" : null
    overwrite = true
}
