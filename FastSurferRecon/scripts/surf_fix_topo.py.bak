#!/usr/bin/env python3
"""
Python-based topology fix for cortical surfaces.

Tries multiple mesh repair libraries and compares results:
- pymeshfix (MeshFix wrapper)
- trimesh
- PyVista (VTK-based)
- Open3D

Usage:
    python surf_fix_topo.py input.surf output.surf [--method auto]
"""

import sys
import argparse
import logging
from pathlib import Path
from typing import Tuple, Optional
import numpy as np

logging.basicConfig(level=logging.INFO, format='%(levelname)s: %(message)s')
logger = logging.getLogger(__name__)


def load_freesurfer_surface(path: Path) -> Tuple[np.ndarray, np.ndarray]:
    """Load FreeSurfer surface file."""
    try:
        import nibabel.freesurfer as fs
        vertices, faces = fs.read_geometry(path)
        logger.info(f"Loaded surface: {vertices.shape[0]} vertices, {faces.shape[0]} faces")
        return vertices, faces
    except Exception as e:
        logger.error(f"Failed to load surface: {e}")
        raise


def save_freesurfer_surface(path: Path, vertices: np.ndarray, faces: np.ndarray) -> None:
    """Save FreeSurfer surface file."""
    try:
        import nibabel.freesurfer as fs
        fs.write_geometry(path, vertices, faces)
        logger.info(f"Saved surface: {path}")
    except Exception as e:
        logger.error(f"Failed to save surface: {e}")
        raise


def check_euler_number(vertices: np.ndarray, faces: np.ndarray) -> int:
    """
    Calculate Euler number: V - E + F = 2 - 2g
    Where g is genus (0 for topologically correct sphere).
    """
    n_vertices = len(vertices)
    n_faces = len(faces)
    
    # Count edges using edge set
    edges = set()
    for face in faces:
        for i in range(3):
            edge = tuple(sorted([face[i], face[(i + 1) % 3]]))
            edges.add(edge)
    n_edges = len(edges)
    
    euler = n_vertices - n_edges + n_faces
    genus = (2 - euler) // 2
    
    logger.info(f"  V={n_vertices}, E={n_edges}, F={n_faces}")
    logger.info(f"  Euler number: {euler} (genus={genus}, holes={genus})")
    
    return euler


def check_closed(vertices: np.ndarray, faces: np.ndarray) -> bool:
    """
    Check if mesh is closed (no boundary edges).
    Boundary edge = edge that belongs to only one face.
    """
    from collections import defaultdict
    
    edge_count = defaultdict(int)
    for face in faces:
        for i in range(3):
            edge = tuple(sorted([face[i], face[(i + 1) % 3]]))
            edge_count[edge] += 1
    
    boundary_edges = [edge for edge, count in edge_count.items() if count == 1]
    
    if boundary_edges:
        logger.warning(f"  Mesh has {len(boundary_edges)} boundary edges (NOT closed)")
        return False
    else:
        logger.info(f"  Mesh is closed (no boundary edges) ✓")
        return True


def method_pymeshfix(vertices: np.ndarray, faces: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
    """
    Use pymeshfix to repair mesh.
    
    pymeshfix is a wrapper around MeshFix (C++ tool).
    Very good at closing holes and fixing non-manifold geometry.
    """
    logger.info("\n=== Trying pymeshfix ===")
    try:
        import pymeshfix
        logger.info("  pymeshfix available ✓")
    except ImportError:
        logger.error("  pymeshfix not available. Install: pip install pymeshfix")
        return None, None
    
    try:
        # Create meshfix object (MeshFix.points / MeshFix.faces for output)
        meshfix = pymeshfix.MeshFix(vertices, faces)
        
        # Repair: joincomp=True, keep all components (cortical surface is one component)
        logger.info("  Repairing mesh (this may take a while)...")
        meshfix.repair(
            joincomp=True,                       # Join nearby open components
            remove_smallest_components=False,    # Keep all components
        )
        
        # Get repaired mesh (pymeshfix uses .points and .faces, not .v and .f)
        v_repaired = np.asarray(meshfix.points)
        f_repaired = np.asarray(meshfix.faces)
        
        logger.info(f"  Repaired: {v_repaired.shape[0]} vertices, {f_repaired.shape[0]} faces")
        check_closed(v_repaired, f_repaired)
        check_euler_number(v_repaired, f_repaired)
        
        return v_repaired, f_repaired
        
    except Exception as e:
        logger.error(f"  pymeshfix failed: {e}")
        return None, None


def method_trimesh(vertices: np.ndarray, faces: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
    """
    Use trimesh to repair mesh.
    
    trimesh is pure Python, good for basic repairs.
    """
    logger.info("\n=== Trying trimesh ===")
    try:
        import trimesh
        logger.info("  trimesh available ✓")
    except ImportError:
        logger.error("  trimesh not available. Install: pip install trimesh")
        return None, None
    
    try:
        # Create mesh
        mesh = trimesh.Trimesh(vertices=vertices, faces=faces)
        logger.info(f"  Created trimesh: watertight={mesh.is_watertight}, volume={mesh.is_volume}")
        
        # Fill holes
        logger.info("  Filling holes...")
        mesh.fill_holes()
        
        # Fix normals
        logger.info("  Fixing normals...")
        mesh.fix_normals()
        
        # Remove degenerate faces
        logger.info("  Removing degenerate faces...")
        mesh.remove_degenerate_faces()
        
        # Remove duplicate faces
        logger.info("  Removing duplicate faces...")
        mesh.remove_duplicate_faces()
        
        # Merge vertices
        logger.info("  Merging vertices...")
        mesh.merge_vertices()
        
        v_repaired = mesh.vertices
        f_repaired = mesh.faces
        
        logger.info(f"  Repaired: {v_repaired.shape[0]} vertices, {f_repaired.shape[0]} faces")
        logger.info(f"  Result: watertight={mesh.is_watertight}, volume={mesh.is_volume}")
        
        # Check results
        is_closed = check_closed(v_repaired, f_repaired)
        euler = check_euler_number(v_repaired, f_repaired)
        
        return v_repaired, f_repaired
        
    except Exception as e:
        logger.error(f"  trimesh failed: {e}")
        import traceback
        traceback.print_exc()
        return None, None


def method_pyvista(vertices: np.ndarray, faces: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
    """
    Use PyVista (VTK) to repair mesh.
    
    PyVista has powerful mesh repair capabilities via VTK.
    """
    logger.info("\n=== Trying PyVista ===")
    try:
        import pyvista as pv
        logger.info("  PyVista available ✓")
    except ImportError:
        logger.error("  PyVista not available. Install: pip install pyvista")
        return None, None
    
    try:
        # Convert to PyVista format
        # PyVista faces format: [n_points, v1, v2, v3, n_points, v1, v2, v3, ...]
        pv_faces = np.hstack([[3] + list(face) for face in faces])
        mesh = pv.PolyData(vertices, pv_faces)
        
        logger.info(f"  Created PyVista mesh: {mesh.n_points} points, {mesh.n_cells} faces")
        logger.info(f"  Is manifold: {mesh.is_manifold}")
        
        # Fill holes
        logger.info("  Filling holes...")
        mesh_filled = mesh.fill_holes(hole_size=1000.0)
        
        # Clean mesh (merge duplicate points, remove unused points)
        logger.info("  Cleaning mesh...")
        mesh_clean = mesh_filled.clean(tolerance=1e-6)
        
        # Smooth to fix irregularities (optional, light smoothing)
        logger.info("  Light smoothing...")
        mesh_smooth = mesh_clean.smooth(n_iter=5, relaxation_factor=0.01)
        
        # Extract vertices and faces
        v_repaired = mesh_smooth.points
        # Convert PyVista faces back to standard format
        faces_raw = mesh_smooth.faces
        f_repaired = faces_raw.reshape(-1, 4)[:, 1:4]  # Remove the leading "3"
        
        logger.info(f"  Repaired: {v_repaired.shape[0]} vertices, {f_repaired.shape[0]} faces")
        logger.info(f"  Is manifold: {mesh_smooth.is_manifold}")
        
        # Check results
        is_closed = check_closed(v_repaired, f_repaired)
        euler = check_euler_number(v_repaired, f_repaired)
        
        return v_repaired, f_repaired
        
    except Exception as e:
        logger.error(f"  PyVista failed: {e}")
        import traceback
        traceback.print_exc()
        return None, None


def method_open3d(vertices: np.ndarray, faces: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
    """
    Use Open3D to repair mesh.
    
    Open3D has mesh repair and reconstruction capabilities.
    """
    logger.info("\n=== Trying Open3D ===")
    try:
        import open3d as o3d
        logger.info("  Open3D available ✓")
    except ImportError:
        logger.error("  Open3D not available. Install: pip install open3d")
        return None, None
    
    try:
        # Create Open3D mesh
        mesh = o3d.geometry.TriangleMesh()
        mesh.vertices = o3d.utility.Vector3dVector(vertices)
        mesh.triangles = o3d.utility.Vector3iVector(faces)
        
        logger.info(f"  Created Open3D mesh: {len(mesh.vertices)} vertices, {len(mesh.triangles)} faces")
        logger.info(f"  Is watertight: {mesh.is_watertight()}")
        logger.info(f"  Is vertex manifold: {mesh.is_vertex_manifold()}")
        logger.info(f"  Is edge manifold: {mesh.is_edge_manifold()}")
        
        # Remove degenerate triangles
        logger.info("  Removing degenerate triangles...")
        mesh.remove_degenerate_triangles()
        
        # Remove duplicated triangles
        logger.info("  Removing duplicated triangles...")
        mesh.remove_duplicated_triangles()
        
        # Remove duplicated vertices
        logger.info("  Removing duplicated vertices...")
        mesh.remove_duplicated_vertices()
        
        # Remove non-manifold edges
        logger.info("  Removing non-manifold edges...")
        mesh.remove_non_manifold_edges()
        
        # Compute vertex normals
        logger.info("  Computing normals...")
        mesh.compute_vertex_normals()
        
        # Orient triangles consistently
        logger.info("  Orienting triangles...")
        mesh.orient_triangles()
        
        # Extract vertices and faces
        v_repaired = np.asarray(mesh.vertices)
        f_repaired = np.asarray(mesh.triangles)
        
        logger.info(f"  Repaired: {v_repaired.shape[0]} vertices, {f_repaired.shape[0]} faces")
        logger.info(f"  Is watertight: {mesh.is_watertight()}")
        logger.info(f"  Is vertex manifold: {mesh.is_vertex_manifold()}")
        logger.info(f"  Is edge manifold: {mesh.is_edge_manifold()}")
        
        # Check results
        is_closed = check_closed(v_repaired, f_repaired)
        euler = check_euler_number(v_repaired, f_repaired)
        
        return v_repaired, f_repaired
        
    except Exception as e:
        logger.error(f"  Open3D failed: {e}")
        import traceback
        traceback.print_exc()
        return None, None


def method_combined(vertices: np.ndarray, faces: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
    """
    Combined approach: use multiple methods in sequence.
    
    Strategy:
    1. trimesh for basic cleaning
    2. pymeshfix for aggressive hole filling
    3. Check and iterate if needed
    """
    logger.info("\n=== Trying combined approach ===")
    
    # Step 1: trimesh cleaning
    logger.info("Step 1: trimesh basic cleaning")
    v_clean, f_clean = method_trimesh(vertices, faces)
    if v_clean is None:
        logger.error("  trimesh failed, skipping combined approach")
        return None, None
    
    # Step 2: Check if we need more work
    is_closed = check_closed(v_clean, f_clean)
    euler = check_euler_number(v_clean, f_clean)
    
    if is_closed and euler == 2:
        logger.info("  Already perfect after trimesh! ✓")
        return v_clean, f_clean
    
    # Step 3: Try pymeshfix for more aggressive repair
    logger.info("Step 2: pymeshfix aggressive repair")
    method_pymeshfix(v_clean, f_clean)

def main():
    parser = argparse.ArgumentParser(
        description="Python-based topology fix for cortical surfaces",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Methods:
  auto          - Try all methods and pick best result (default)
  pymeshfix     - Use pymeshfix (MeshFix wrapper)
  trimesh       - Use trimesh
  pyvista       - Use PyVista (VTK)
  open3d        - Use Open3D
  combined      - Use multiple methods in sequence
  
Examples:
  python surf_fix_topo.py lh.orig.nofix lh.orig.fixed
  python surf_fix_topo.py lh.orig.nofix lh.orig.fixed --method pymeshfix
  python surf_fix_topo.py lh.orig.nofix lh.orig.fixed --method auto --verbose
        """
    )
    
    parser.add_argument('input', type=Path, help='Input surface file')
    parser.add_argument('output', type=Path, help='Output surface file')
    parser.add_argument('--method', default='auto', 
                       choices=['auto', 'pymeshfix', 'trimesh', 'pyvista', 'open3d', 'combined'],
                       help='Repair method (default: auto)')
    parser.add_argument('--verbose', action='store_true', help='Verbose output')
    
    args = parser.parse_args()
    
    if args.verbose:
        logging.getLogger().setLevel(logging.DEBUG)
    
    # Load input surface
    logger.info(f"\nLoading input surface: {args.input}")
    vertices, faces = load_freesurfer_surface(args.input)
    
    # Check input topology
    logger.info("\nInput surface topology:")
    is_closed_input = check_closed(vertices, faces)
    euler_input = check_euler_number(vertices, faces)
    
    # Select method(s)
    methods = {
        'pymeshfix': method_pymeshfix,
        'trimesh': method_trimesh,
        'pyvista': method_pyvista,
        'open3d': method_open3d,
        'combined': method_combined,
    }
    
    if args.method == 'auto':
        logger.info("\n" + "="*60)
        logger.info("AUTO MODE: Trying all methods and picking best result")
        logger.info("="*60)
        
        results = {}
        for method_name, method_func in methods.items():
            try:
                v_fixed, f_fixed = method_func(vertices, faces)
                if v_fixed is not None:
                    is_closed = check_closed(v_fixed, f_fixed)
                    euler = check_euler_number(v_fixed, f_fixed)
                    results[method_name] = {
                        'vertices': v_fixed,
                        'faces': f_fixed,
                        'closed': is_closed,
                        'euler': euler,
                        'score': (1000 if is_closed else 0) + euler,  # Prefer closed + high Euler
                    }
            except Exception as e:
                logger.error(f"  {method_name} crashed: {e}")
                continue
        
        if not results:
            logger.error("\nAll methods failed!")
            sys.exit(1)
        
        # Pick best result
        logger.info("\n" + "="*60)
        logger.info("RESULTS SUMMARY:")
        logger.info("="*60)
        for method_name, result in results.items():
            logger.info(f"{method_name:15s}: Euler={result['euler']:3d}, Closed={result['closed']}, Score={result['score']:4d}")
        
        best_method = max(results.items(), key=lambda x: x[1]['score'])
        logger.info(f"\nBest method: {best_method[0]} ✓")
        
        v_final = best_method[1]['vertices']
        f_final = best_method[1]['faces']
        
    else:
        # Single method
        method_func = methods[args.method]
        result = method_func(vertices, faces)
        if result[0] is None:
            logger.error(f"\n{args.method} failed!")
            sys.exit(1)
        v_final, f_final = result
    
    # Save output
    logger.info(f"\n" + "="*60)
    logger.info(f"Saving output to: {args.output}")
    save_freesurfer_surface(args.output, v_final, f_final)
    
    logger.info("\n" + "="*60)
    logger.info("DONE! ✓")
    logger.info("="*60)
    logger.info(f"\nTo verify: mris_euler_number {args.output}")


if __name__ == "__main__":
    main()
