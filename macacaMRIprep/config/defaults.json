{
  "_description": "Default configuration for macacaMRIprep preprocessing pipeline",
  "_version": "1.1",
  
  "general": {
    "dataset_dir": ".",
    "output_dir": ".",
    "working_dir": ".",
    "pipeline_name": "func2anat2template",
    "verbose": 2,
    "log_level": "INFO",
    "overwrite": false,
    "generate_report_only": false,
    "n_procs": 1,
    "anat_only": false,
    "func_only": false
  },

  "caching": {
    "check_outputs": true
  },

  "bids_filtering": {
    "subjects": null,
    "sessions": null,
    "tasks": null,
    "runs": null
  },

  "template": {
    "output_space": "NMT2Sym:res-05",
    "description": "Template space specification in format TEMPLATE_NAME:[:DESCRIPTION]",
    "examples": [
      "NMT2Sym:res-1",
      "NMT2Sym:res-025", 
      "NMT2Sym:res-1:hemi-lh:brainWoCerebellumBrainstem"
    ]
  },

  "anat": {
    "bias_correction": {
      "enabled": true,
      "algorithm": "N4BiasFieldCorrection",
      "dimension": 3,
      "shrink_factor": 2,
      "bspline_fitting": "[ 100 ]",
      "rescale_mean_to_100": true
    },
    "skullstripping": {
      "enabled": true,
      "method": "unet",
      "bet": {
        "fractional_intensity": 0.3
      },
      "unet": {
        "gpu_device": "auto"
      }
    },
    "t2w": {
      "enabled": true
    }
  },

  "func": {
    "slice_timing_correction": {
      "enabled": false,
      "repetition_time": null,
      "slice_timing": null,
      "tzero": null,
      "slice_time_ref": 0.5,
      "slice_encoding_direction": "z"
    },
    "motion_correction": {
      "enabled": true,
      "dof": 6,
      "cost": "mutualinfo",
      "smooth": 1.0,
      "ref_vol": "mid",
      "cost_tolerance": 0.01,
      "parameter_tolerance": 0.01
    },
    "despike": {
      "enabled": true,
      "c1": 5,
      "c2": 10,
      "localedit": true,
      "ignore_first_volumes": 0
    },
    "skullstripping": {
      "enabled": true,
      "method": "bet",
      "bet": {
        "fractional_intensity": 0.3
      },
      "unet": {
        "gpu_device": "auto"
      }
    },
    "bias_correction": {
      "enabled": true,
      "algorithm": "N4BiasFieldCorrection",
      "dimension": 3,
      "shrink_factor": 2,
      "bspline_fitting": "[ 100 ]",
      "rescale_mean_to_100": true
    },
    "smoothing": {
      "enabled": false,
      "fwhm": 1.0,
      "kernel": "gaussian"
    },
    "bandpass_filter": {
      "enabled": false,
      "high_pass": 0.01,
      "low_pass": 0.1,
      "tr": null
    }
  },
  
  "registration": {
    "enabled": true,
    "func2template_xfm_type": "syn",
    "anat2template_xfm_type": "syn",
    "func2anat_xfm_type": "syn",
    "keep_original_func_resolution": true,
    "interpolation": "LanczosWindowedSinc",
    "collapse_output_transforms": 1,
    "write_composite_transform": 1,
    "winsorize_image_intensities": "[0.005,0.995]",
    "use_histogram_matching": 0,
    "initial_moving_transform": "[fixed,moving,1]",
    "output_registered_image": true,
    "output_inverse_registered_image": false,

    "translation": {
      "gradient_step": "[0.1]",
      "metric": ["MI[fixed,moving,1,32,regular,0.25]"],
      "shrink": "8x4x2x1",
      "convergence": "[1000x500x250x100,1e-6,10]",
      "smooth": "3x2x1x0vox"
    },
    
    "rigid": {
      "gradient_step": "[0.1]",
      "metric": ["MI[fixed,moving,1,32,regular,0.25]"],
      "shrink": "8x4x2x1",
      "convergence": "[1000x500x250x100,1e-6,10]",
      "smooth": "3x2x1x0vox"
    },
    
    "affine": {
      "gradient_step": "[0.1]",
      "metric": ["MI[fixed,moving,1,32,regular,0.25]"],
      "shrink": "8x4x2x1",
      "convergence": "[1000x500x250x100,1e-6,10]",
      "smooth": "3x2x1x0vox"
    },
    
    "syn": {
      "gradient_step": "[0.1,3,0]",
      "metric": [
        "mattes[fixed,moving,0.5,32,regular,0.3]",
        "cc[fixed,moving,0.5,4,regular,0.3]"
      ],
      "shrink": "4x2x1",
      "convergence": "[500x300x100,1e-8,10]",
      "smooth": "1x0.5x0vox"
    }
  },
  
  "quality_control": {
    "enabled": true,
    "snap_overlay": true,
    "snap_contour": true,
    "snap_slices": 7,
    "generate_reports": true,
    "report_format": "html"
  },

  "output": {
    "compression": true
  }
}
